# Copy to .env for local development. Never commit real secrets.

# Required for speaker diarization.
HF_TOKEN=

# Required when LLM_PROVIDER=gemini.
GEMINI_API_KEY=

# Optional movie metadata lookup.
TMDB_API_KEY=

# Runtime defaults.
CONFIG_PATH=config.yaml
ML_DEVICE=auto
OUTPUT_DIR=data/processed
VIDEO_DATA_PATH=data/videos
SPEAKER_UI_MODE=external

# Service networking.
API_HOST=localhost
API_PORT=1234
UI_HOST=0.0.0.0
UI_PORT=5050
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=video_search_engine
RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2F
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
STREAMLIT_PORT=8501
SPEAKER_UI_PORT=5050
INGESTION_QUEUE=video.ingestion

# LLM provider.
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_HOST=http://localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma:2b

# Local model cache.
MODEL_CACHE_DIR=.models
